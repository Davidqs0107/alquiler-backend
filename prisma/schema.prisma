generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  SUPERADMIN
  USER
}

enum MembershipRole {
  ADMIN_EMPRESA
  ADMIN_SEDE
  CAJERO
  RECEPCION
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum PricingType {
  BLOCK
  TIME_UNIT
}

enum TicketStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum TicketItemType {
  RENTAL
  PRODUCT
  EXTRA
  MANUAL
}

enum RentalSessionStatus {
  RESERVED
  IN_USE
  FINISHED
  CANCELLED
}

enum CatalogItemType {
  PRODUCT
  SERVICE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  DIGITAL_WALLET
  OTHER
}

model User {
  id                 String        @id @default(cuid())
  email              String        @unique
  passwordHash       String
  globalRole         GlobalRole    @default(USER)
  status             RecordStatus  @default(ACTIVE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  companyMemberships CompanyUser[]
  branchMemberships  BranchUser[]
  openedTickets      Ticket[]      @relation("TicketOpenedBy")
}

model Company {
  id                         String                     @id @default(cuid())
  name                       String
  slug                       String                     @unique
  status                     RecordStatus               @default(ACTIVE)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  branches                   Branch[]
  users                      CompanyUser[]
  resourceCategories         ResourceCategory[]
  branchCategoryVisibilities BranchCategoryVisibility[]
  resources                  Resource[]
  ratePlans                  RatePlan[]
  tickets                    Ticket[]
  catalogItems               SaleCatalogItem[]
  payments                   Payment[]
  rentalSessions             RentalSession[]
}

model Branch {
  id                          String                     @id @default(cuid())
  companyId                   String
  name                        String
  status                      RecordStatus               @default(ACTIVE)
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt
  company                     Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users                       BranchUser[]
  resources                   Resource[]
  ratePlans                   RatePlan[]
  tickets                     Ticket[]
  sessions                    RentalSession[]
  catalogItems                SaleCatalogItem[]
  categoryVisibilityOverrides BranchCategoryVisibility[]

  @@unique([companyId, name])
  @@index([companyId])
}

model CompanyUser {
  id        String         @id @default(cuid())
  companyId String
  userId    String
  role      MembershipRole
  status    RecordStatus   @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

model BranchUser {
  id        String         @id @default(cuid())
  branchId  String
  userId    String
  role      MembershipRole
  status    RecordStatus   @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  branch    Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([branchId, userId])
  @@index([branchId])
  @@index([userId])
}

model ResourceCategory {
  id                  String                     @id @default(cuid())
  companyId           String
  name                String
  status              RecordStatus               @default(ACTIVE)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  company             Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  resources           Resource[]
  ratePlans           RatePlan[]
  visibilityOverrides BranchCategoryVisibility[]

  @@unique([companyId, name])
  @@index([companyId])
}

model BranchCategoryVisibility {
  id                 String           @id @default(cuid())
  companyId          String
  branchId           String
  resourceCategoryId String
  isVisible          Boolean
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch             Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  resourceCategory   ResourceCategory @relation(fields: [resourceCategoryId], references: [id], onDelete: Cascade)

  @@unique([branchId, resourceCategoryId])
  @@index([companyId])
  @@index([companyId, branchId])
}

model Resource {
  id                 String           @id @default(cuid())
  companyId          String
  branchId           String
  resourceCategoryId String
  name               String
  status             RecordStatus     @default(ACTIVE)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch             Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category           ResourceCategory @relation(fields: [resourceCategoryId], references: [id], onDelete: Restrict)
  ratePlans          RatePlan[]
  sessions           RentalSession[]

  @@unique([branchId, name])
  @@index([companyId])
  @@index([companyId, branchId])
}

model RatePlan {
  id                 String            @id @default(cuid())
  companyId          String
  branchId           String
  resourceCategoryId String?
  resourceId         String?
  name               String
  pricingType        PricingType
  basePrice          Decimal           @db.Decimal(12, 2)
  timeUnitMinutes    Int?
  status             RecordStatus      @default(ACTIVE)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  company            Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch             Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  resourceCategory   ResourceCategory? @relation(fields: [resourceCategoryId], references: [id], onDelete: SetNull)
  resource           Resource?         @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  rules              RatePlanRule[]

  @@index([companyId])
  @@index([companyId, branchId])
}

model RatePlanRule {
  id            String   @id @default(cuid())
  ratePlanId    String
  name          String
  dayOfWeek     Int?
  startMinute   Int?
  endMinute     Int?
  priceOverride Decimal? @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  ratePlan      RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@index([ratePlanId])
}

model Ticket {
  id           String       @id @default(cuid())
  companyId    String
  branchId     String
  openedById   String
  ticketNumber Int
  status       TicketStatus @default(OPEN)
  subtotal     Decimal      @default(0) @db.Decimal(12, 2)
  total        Decimal      @default(0) @db.Decimal(12, 2)
  openedAt     DateTime     @default(now())
  closedAt     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  openedBy     User         @relation("TicketOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  items        TicketItem[]
  payments     Payment[]

  @@unique([branchId, ticketNumber])
  @@index([companyId])
  @@index([companyId, branchId])
  @@index([status])
  @@index([openedAt])
}

model TicketItem {
  id            String         @id @default(cuid())
  ticketId      String
  type          TicketItemType
  description   String
  quantity      Decimal        @db.Decimal(12, 2)
  unitPrice     Decimal        @db.Decimal(12, 2)
  subtotal      Decimal        @db.Decimal(12, 2)
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  ticket        Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  rentalSession RentalSession?

  @@index([ticketId])
}

model RentalSession {
  id               String              @id @default(cuid())
  companyId        String
  branchId         String
  resourceId       String
  ticketItemId     String              @unique
  status           RentalSessionStatus @default(RESERVED)
  startAt          DateTime
  scheduledEndAt   DateTime
  endedAt          DateTime?
  reservedMinutes  Int
  usedMinutes      Int?
  overtimeMinutes  Int?                @default(0)
  ratePlanSnapshot Json?
  baseAmount       Decimal             @default(0) @db.Decimal(12, 2)
  overtimeAmount   Decimal             @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal             @default(0) @db.Decimal(12, 2)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch           Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  resource         Resource            @relation(fields: [resourceId], references: [id], onDelete: Restrict)
  ticketItem       TicketItem          @relation(fields: [ticketItemId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, branchId])
  @@index([resourceId, startAt, scheduledEndAt])
  @@index([status])
}

model Payment {
  id        String        @id @default(cuid())
  companyId String
  ticketId  String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ticket    Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([ticketId])
}

model SaleCatalogItem {
  id        String          @id @default(cuid())
  companyId String
  branchId  String?
  type      CatalogItemType
  name      String
  price     Decimal         @db.Decimal(12, 2)
  status    RecordStatus    @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, branchId])
}
